---
// Custom page — full-viewport workflow visualizer
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Workflow Visualizer | OrchStep</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }

    .topbar {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 0 20px;
      height: 44px;
      background: #111;
      color: white;
      border-bottom: 1px solid #333;
    }
    .topbar a.brand {
      color: #e94560;
      text-decoration: none;
      font-weight: 700;
      font-size: 16px;
    }
    .topbar .title {
      color: #888;
      font-size: 14px;
    }
    .topbar .spacer { flex: 1; }
    .topbar .nav-link {
      color: #aaa;
      font-size: 13px;
      text-decoration: none;
    }
    .topbar .nav-link:hover { color: white; }

    #visualizer-root {
      width: 100%;
      height: calc(100vh - 44px);
    }
  </style>
</head>
<body>
  <div class="topbar">
    <a class="brand" href="/">OrchStep</a>
    <span class="title">Workflow Visualizer</span>
    <div class="spacer"></div>
    <a class="nav-link" href="/getting-started/introduction">Docs</a>
    <a class="nav-link" href="https://github.com/orchstep/orchstep" target="_blank">GitHub</a>
  </div>
  <div id="visualizer-root"></div>

  <script>
    import { createElement } from 'react';
    import { createRoot } from 'react-dom/client';
    import VisualizePage from '../components/VisualizePage';
    import '@xyflow/react/dist/style.css';

    const root = createRoot(document.getElementById('visualizer-root'));
    root.render(createElement(VisualizePage));
  </script>
</body>
</html>
